---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';
import data from '../../data/bars_food_by_city.json';

const cities = [...data.cities].sort((a, b) => a.name.localeCompare(b.name, 'pt-BR'));
const venueCount = cities.reduce((total, city) => total + city.venues.length, 0);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Brazil Food Guide | ${SITE_TITLE}`}
			description="A pre-launch city-by-city guide to iconic restaurants, markets, cafes and botecos in Brazil."
		/>
		<style>
			main {
				max-width: 1080px;
			}
			.hero {
				margin-bottom: 2rem;
			}
			.kicker {
				color: rgb(var(--gray));
				font-size: 0.9rem;
				font-weight: 700;
				letter-spacing: 0;
				text-transform: uppercase;
			}
			.summary {
				display: flex;
				flex-wrap: wrap;
				gap: 0.75rem;
				margin: 1.5rem 0;
			}
			.pill {
				border: 1px solid rgb(var(--gray-light));
				border-radius: 999px;
				background: #fff;
				font-size: 0.95rem;
				padding: 0.35rem 0.75rem;
			}
			.note {
				border-left: 4px solid #27ae60;
				color: rgb(var(--gray-dark));
				margin: 2rem 0;
				padding-left: 1rem;
			}
			.city-grid {
				display: grid;
				grid-template-columns: repeat(3, minmax(0, 1fr));
				gap: 1rem;
			}
			.city-card {
				background: #fff;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 8px;
				padding: 1rem;
			}
			.city-card h2 {
				font-size: 1.25rem;
				margin-bottom: 0.25rem;
			}
			.city-card a {
				text-decoration: none;
			}
			.city-card p {
				color: rgb(var(--gray));
				font-size: 0.95rem;
				margin: 0.25rem 0 0;
			}
			@media (max-width: 820px) {
				.city-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="kicker">Brazil Food Guide</div>
				<h1>Iconic Food Stops by City</h1>
				<p>
					A first map of restaurants, markets, cafes, botecos and street-food references that help travelers understand Brazilian cities through food.
				</p>
				<div class="summary" aria-label="Food guide summary">
					<span class="pill">{cities.length} cities</span>
					<span class="pill">{venueCount} venues</span>
					<span class="pill">Pre-launch curation</span>
				</div>
			</section>

			<p class="note">
				This is an early editorial curation, not an official registry. Opening hours, prices and operating status may change. Last review: May 2026.
				Corrections can be sent to migueldorosario@gmail.com.
			</p>

			<section class="city-grid" aria-label="Food cities">
				{
					cities.map((city) => (
						<article class="city-card">
							<h2><a href={`/food/${city.slug}`}>{city.menu_label_en}</a></h2>
							<p>{city.state}, Brazil</p>
							<p>{city.venues.length} selected venues.</p>
						</article>
					))
				}
			</section>
		</main>
		<Footer />
	</body>
</html>
